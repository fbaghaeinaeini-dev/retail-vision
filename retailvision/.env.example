# RetailVision Configuration
# Copy to .env and fill in your API keys

# OpenRouter API key for VLM calls (Qwen3.5)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Replicate API token for Depth Pro (optional — pipeline works without it)
REPLICATE_API_TOKEN=r8_your-token-here

# Paths (defaults work for most setups)
DB_PATH=data/retailvision.db
OUTPUT_DIR=output

# Tracker settings
YOLO_MODEL=yolo11m.pt
DETECTION_CONF=0.25
IMGSZ=1280
KEYFRAME_INTERVAL=150

# VLM settings
VLM_PRIMARY_MODEL=qwen/qwen2.5-vl-72b-instruct
VLM_FALLBACK_MODEL=qwen/qwen2.5-vl-7b-instruct
VLM_TEMPERATURE=0.2

# Calibration
BEV_RESOLUTION=0.05
PERSON_HEIGHT_M=1.7

# Quality thresholds
QUALITY_THRESHOLD=0.40
TRACK_QUALITY_THRESHOLD=0.3
