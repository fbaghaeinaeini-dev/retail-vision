%%{init: {'theme': 'dark', 'themeVariables': {'fontSize': '12px'}}}%%

flowchart TB
    subgraph CALIB["t03: calibrate_from_person_height (No API needed)"]
        direction TB
        
        INPUT["Tracking data already has<br/>bbox_h at every y-position<br/>(from YOLOv26 detections)"]
        
        STEP1["1. Bin detections by y-position<br/>20 bands across image height<br/>Compute median bbox_h per band"]
        
        STEP2["2. Fit perspective model<br/>bbox_h = K / (y − y_vanishing)<br/>Least-squares regression"]
        
        STEP3["3. Extract camera parameters<br/>focal_length = K / 1.7m<br/>vanishing point = y_vp"]
        
        STEP4["4. Compute homography<br/>4 reference points →<br/>ground-plane positions<br/>cv2.findHomography"]
        
        STEP5["5. Transform ALL tracks<br/>pixel (x,y) → BEV meters<br/>Recompute speed in m/s"]
        
        VALID["6. Validate: median walking<br/>speed should be 0.5−3.0 m/s"]
        
        INPUT --> STEP1 --> STEP2 --> STEP3 --> STEP4 --> STEP5 --> VALID
    end

    subgraph ENHANCE["t06: depth_scene_analysis (Optional enhancement)"]
        DEPTH["If Replicate API available:<br/>Run Depth Pro on reference frame<br/>→ Refine focal length estimate<br/>→ Get metric depth for VLM context<br/>→ Enable 3D visualization"]
    end

    VALID -->|"Works standalone"| BEV["BEV Calibrated Tracks<br/>All coordinates in meters"]
    VALID -.->|"Optional"| DEPTH
    DEPTH -.->|"Refines"| BEV

    style CALIB fill:#0a1a0a,stroke:#00ff88,stroke-width:2px
    style ENHANCE fill:#0a0a1a,stroke:#339dff,stroke-dasharray: 5 5
    style BEV fill:#0a1a0a,stroke:#00ff88,stroke-width:3px
